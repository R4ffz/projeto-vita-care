# URL do backend Spring (REST). Em dev, o proxy do Vite redireciona /api -> aqui.
VITE_API_URL=http://localhost:8080

# URL do WebSocket STOMP do backend.
VITE_WS_URL=ws://localhost:8080/ws

# URL do servidor de controle do simulador (usado pelo Painel do Simulador).
VITE_SIM_URL=http://localhost:4000
