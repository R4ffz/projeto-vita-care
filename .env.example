# Variáveis opcionais lidas pelo docker-compose.yml.
# Copie para `.env` na raiz e ajuste se quiser sobrescrever os defaults.
# Sem este arquivo, o compose usa os defaults abaixo (adequados pra dev local).

# ───── PostgreSQL ─────────────────────────────────────────────────────────────
# Aplica-se ao container `postgres` e ao backend (mesma senha).
POSTGRES_PASSWORD=vitacare_dev

# ───── JWT ────────────────────────────────────────────────────────────────────
# Segredo HMAC do backend. Mínimo 32 bytes. Em produção, gere com:
#   openssl rand -base64 48
JWT_SECRET=vitacare-iot-dev-secret-troque-em-producao-min-32-bytes-please
