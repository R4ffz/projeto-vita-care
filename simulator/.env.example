# Broker MQTT — mesmo endereço usado pelo docker-compose.yml da raiz
MQTT_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=vitacare-simulator

# IDs dos pacientes a simular (precisam existir no banco; seed do Flyway cria 1, 2, 3)
PATIENT_IDS=1,2,3

# Intervalos de publicação (ms)
SINAIS_INTERVAL_MS=5000
STATUS_INTERVAL_MS=30000

# Servidor HTTP de controle (consumido pelo painel do simulador no frontend)
CONTROL_PORT=4000
